{
  "compilerOptions": {
    "noEmitOnError": true,
    "module": "commonjs",
    "sourceMap": true,
    "target": "es5",
    "declaration": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@layer3/core": ["packages/core/src"]
    },
    "types": [],
    "lib": ["dom", "es5", "scripthost", "es2015.promise"],
    "skipLibCheck": true
  },
  "include": [
    "src",
    "packages/core/src",
    "apps/web/dashboard"
  ],
  "exclude": ["node_modules"]
}
