# ─────────────────────────────────────────────────────────────────────────────
# AI-Automation-MSSQL — Environment Variables Template
# Copy file này thành .env và điền các giá trị thực tế
# ─────────────────────────────────────────────────────────────────────────────

# ── MSSQL Cluster ────────────────────────────────────────────────────────────
# Danh sách tất cả nodes trong AG cluster (comma-separated).
# Service tự detect Primary/Secondary — không cần chỉ định role.
# Comma-separated hoặc JSON array đều được:
#   MSSQL_NODES=SQL-NODE-01,SQL-NODE-02,SQL-NODE-03
#   MSSQL_NODES=["SQL-NODE-01","SQL-NODE-02","SQL-NODE-03"]
MSSQL_NODES=SQL-NODE-01,SQL-NODE-02,SQL-NODE-03

# Database cần monitor
MSSQL_DATABASE=YourDatabase

# Service account (cần: VIEW SERVER STATE, VIEW DATABASE STATE)
MSSQL_USERNAME=sa_monitor
MSSQL_PASSWORD=change_me

# SQL Server port (default 1433)
MSSQL_PORT=1433

# Timeout mặc định cho mỗi query (giây). Có thể override per-query trong MongoDB
MSSQL_QUERY_TIMEOUT_SEC=30

# ── MongoDB ───────────────────────────────────────────────────────────────────
# MongoDB Community chạy local (default)
MONGODB_URI=mongodb://localhost:27017

# Database name cho monitoring data
MONGODB_DB=db_monitor

# ── Node Role Cache ───────────────────────────────────────────────────────────
# Refresh AG node roles mỗi N giây (default 3600 = 1 giờ)
NODE_ROLE_REFRESH_SEC=3600

# Suppress alert trùng theo finding_hash trong N phút (default 30)
DEDUP_SUPPRESS_MINUTES=30

# ── Notifications — điền kênh bạn muốn dùng, để trống = không gửi ─────────────
# Microsoft Teams (Incoming Webhook URL)
TEAMS_WEBHOOK_URL=

# Slack (Bot Token — xoxb-...)
SLACK_BOT_TOKEN=

# Telegram (Layer 1 Bot Token + Chat ID)
# Chat ID: nhắn /start cho @userinfobot để lấy ID của bạn
# Hoặc group chat: thêm bot vào group → gọi getUpdates API
# Layer 1 bot gửi alert + /quick command
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telegram Layer 2 Bot Token (riêng để tránh polling conflict)
# Layer 2 bot xử lý /analyze, /summary, multi-turn reply
# Nếu để trống → Layer 2 Telegram bot không khởi động (API vẫn hoạt động)
L2_TELEGRAM_BOT_TOKEN=

# ── AI Agent ─────────────────────────────────────────────────────────────────
# Claude API key — cần cho /quick command (Haiku analysis Layer 1)
CLAUDE_API_KEY=

# Sonnet model — dùng cho Layer 2 agent (config, không cần thiết cho Layer 1)
CLAUDE_MODEL=claude-sonnet-4-6

# Haiku model — dùng cho /quick command (phân tích nhanh rẻ)
HAIKU_MODEL=claude-haiku-4-5-20251001

# Layer 2 FastAPI agent URL — để Layer 1 forward /analyze requests
# Format: http://layer2:8000 (khi dùng Docker Compose)
# Để trống = /analyze disabled
LAYER2_URL=http://layer2:8000

# ── Logging ──────────────────────────────────────────────────────────────────
L1_LOG_LEVEL=INFO
L2_LOG_LEVEL=INFO
# LOG_LEVEL=INFO

# ── Logstash centralized logging — để trống LOGSTASH_HOST = disable ──────────
# Logstash input phải là: tcp { port => 5044 codec => json_lines }
LOGSTASH_HOST=10.100.110.185
LOGSTASH_PORT=5044
LOGSTASH_TRANSPORT=tcp
L1_LOGSTASH_APP_NAME=sds.ep.ai-automation-layer1
L2_LOGSTASH_APP_NAME=sds.ep.ai-automation-layer2
# LOGSTASH_APP_NAME=sds.ep.ai-automation   # fallback legacy neu muon dung chung
# Persistent SQLite queue (recommended cho production để không mất log khi restart).
# Trống = in-memory queue (queue mất khi container chết).
LOGSTASH_DATABASE_PATH=/var/lib/layer1/logstash/queue.db
