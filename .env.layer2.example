# ─────────────────────────────────────────────────────────────────────────────
# Layer 2 — AI Analysis Agent — Environment Variables
# Copy file này thành .env.layer2 và điền giá trị thực tế
# ─────────────────────────────────────────────────────────────────────────────

# ── MSSQL (giống Layer 1 — cùng cluster, cùng service account) ───────────────
MSSQL_NODES=SQL-NODE-01,SQL-NODE-02,SQL-NODE-03
MSSQL_DATABASE=YourDatabase
MSSQL_USERNAME=sa_monitor
MSSQL_PASSWORD=change_me
MSSQL_PORT=1433
MSSQL_QUERY_TIMEOUT_SEC=30

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=db_monitor

# ── Claude AI (bắt buộc) ─────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── Telegram Bot Layer 2 (dùng BOT TOKEN RIÊNG, khác Layer 1) ────────────────
# Layer 1 dùng bot để gửi alert. Layer 2 dùng bot để nhận /analyze command.
# Tạo bot mới qua @BotFather → lấy token riêng.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Agent Runtime ─────────────────────────────────────────────────────────────
AGENT_TIMEOUT_SEC=120
NODE_ROLE_REFRESH_SEC=3600

# ── Peak Hours (VN time, tool nặng bị block trong khoảng này) ────────────────
PEAK_HOURS_START=8
PEAK_HOURS_END=18

# ── DB Context ────────────────────────────────────────────────────────────────
DB_CONTEXT_MAX_TABLES=50
DB_CONTEXT_MAX_AGE_HOURS=24

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOGSTASH_HOST=
LOGSTASH_PORT=5044
LOGSTASH_APP_NAME=sds.ep.ai-automation-layer2
LOGSTASH_DATABASE_PATH=
